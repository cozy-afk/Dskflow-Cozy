<Window x:Class="CozyDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cozy" Height="680" Width="960"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Bg}"
        FontFamily="Segoe UI Variable, Segoe UI">

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,18">
            <TextBlock Text="Cozy" FontSize="34" FontWeight="Bold" />
            <TextBlock Text="One keyboard &amp; mouse across your PC, Mac, and tablet."
                       Foreground="{StaticResource Muted}" FontSize="14" Margin="0,2,0,0" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Big status + action card -->
                <Border Style="{StaticResource Card}" Padding="24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse x:Name="StatusDot" Width="12" Height="12" Fill="{StaticResource Muted}"
                                         VerticalAlignment="Center" Margin="0,0,10,0" />
                                <TextBlock x:Name="StatusText" Text="Not sharing" FontSize="20" FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock x:Name="StatusDetail"
                                       Text="Press Start to share this PC's keyboard and mouse."
                                       Foreground="{StaticResource Muted}" Margin="22,6,0,0" />
                        </StackPanel>

                        <Button x:Name="StartButton" Grid.Column="1" Style="{StaticResource PrimaryButton}"
                                Content="Start Sharing" MinWidth="170" Click="StartButton_Click" />
                    </Grid>
                </Border>

                <!-- Engine setup card (shown only when engine missing) -->
                <Border x:Name="EngineCard" Style="{StaticResource Card}" Margin="0,14,0,0"
                        Background="#241C12" BorderBrush="#5A4420" Visibility="Collapsed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="One-time setup needed" FontWeight="SemiBold" FontSize="15" />
                            <TextBlock Text="Cozy needs its sharing engine installed (a quick background component)."
                                       Foreground="{StaticResource Muted}" Margin="0,4,0,0" TextWrapping="Wrap" />
                        </StackPanel>
                        <Button x:Name="InstallButton" Grid.Column="1" Style="{StaticResource PrimaryButton}"
                                Content="Set up Cozy" MinWidth="130" Click="InstallButton_Click" />
                    </Grid>
                </Border>

                <!-- Layout visual + settings -->
                <Border Style="{StaticResource Card}" Margin="0,14,0,0">
                    <StackPanel>
                        <TextBlock Text="Where is your tablet?" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,12" />

                        <!-- side picker -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Button x:Name="SideLeft"  Style="{StaticResource GhostButton}" Content="◀ Left of PC"  Margin="0,0,8,0" Click="Side_Click" Tag="left" />
                            <Button x:Name="SideRight" Style="{StaticResource GhostButton}" Content="Right of PC ▶" Margin="0,0,8,0" Click="Side_Click" Tag="right" />
                            <Button x:Name="SideUp"    Style="{StaticResource GhostButton}" Content="▲ Above"       Margin="0,0,8,0" Click="Side_Click" Tag="up" />
                            <Button x:Name="SideDown"  Style="{StaticResource GhostButton}" Content="▼ Below"       Click="Side_Click" Tag="down" />
                        </StackPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Tablet name" Foreground="{StaticResource Muted}" Margin="2,0,0,5" />
                                <TextBox x:Name="ClientNameBox" Text="android-tablet" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                <TextBlock Text="Port" Foreground="{StaticResource Muted}" Margin="2,0,0,5" />
                                <TextBox x:Name="PortBox" Text="24800" />
                            </StackPanel>
                        </Grid>

                        <CheckBox x:Name="TlsCheck" Content="Use encryption (TLS)" Foreground="{StaticResource Ink}"
                                  Margin="2,14,0,0" IsChecked="True" />

                        <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                            <Button Style="{StaticResource GhostButton}" Content="Open visual layout editor"
                                    Click="OpenEditor_Click" Margin="0,0,8,0" />
                            <TextBlock x:Name="IpText" Text="" Foreground="{StaticResource Muted}"
                                       VerticalAlignment="Center" Margin="6,0,0,0" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Activity log -->
                <Border Style="{StaticResource Card}" Margin="0,14,0,0">
                    <StackPanel>
                        <TextBlock Text="Activity" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,10" />
                        <TextBox x:Name="LogBox" Height="150" IsReadOnly="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto" FontFamily="Cascadia Mono, Consolas"
                                 FontSize="12" Background="#0B0E1A" />
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
