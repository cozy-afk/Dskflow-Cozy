<Window x:Class="CozyDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cozy" Height="680" Width="960"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Bg}"
        FontFamily="Segoe UI Variable, Segoe UI">

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,18">
            <TextBlock Text="Cozy" FontSize="34" FontWeight="Bold" />
            <TextBlock Text="One keyboard &amp; mouse across your PC, Mac, and tablet."
                       Foreground="{StaticResource Muted}" FontSize="14" Margin="0,2,0,0" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Big status + action card -->
                <Border Style="{StaticResource Card}" Padding="24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse x:Name="StatusDot" Width="12" Height="12" Fill="{StaticResource Muted}"
                                         VerticalAlignment="Center" Margin="0,0,10,0" />
                                <TextBlock x:Name="StatusText" Text="Not sharing" FontSize="20" FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock x:Name="StatusDetail"
                                       Text="Press Start to share this PC's keyboard and mouse."
                                       Foreground="{StaticResource Muted}" Margin="22,6,0,0" />
                        </StackPanel>

                        <Button x:Name="StartButton" Grid.Column="1" Style="{StaticResource PrimaryButton}"
                                Content="Start Sharing" MinWidth="170" Click="StartButton_Click" />
                    </Grid>
                </Border>

                <!-- Engine setup card (shown only when engine missing) -->
                <Border x:Name="EngineCard" Style="{StaticResource Card}" Margin="0,14,0,0"
                        Background="#241C12" BorderBrush="#5A4420" Visibility="Collapsed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="One-time setup needed" FontWeight="SemiBold" FontSize="15" />
                            <TextBlock Text="Cozy needs its sharing engine installed (a quick background component)."
                                       Foreground="{StaticResource Muted}" Margin="0,4,0,0" TextWrapping="Wrap" />
                        </StackPanel>
                        <Button x:Name="InstallButton" Grid.Column="1" Style="{StaticResource PrimaryButton}"
                                Content="Set up Cozy" MinWidth="130" Click="InstallButton_Click" />
                    </Grid>
                </Border>

                <!-- Devices & layout -->
                <Border Style="{StaticResource Card}" Margin="0,14,0,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Devices &amp; layout" FontWeight="SemiBold" FontSize="15" />
                                <TextBlock Text="Drag tiles to arrange (touching tiles share a cursor edge). Dot colors: grey = not connected, orange = joining, green = connected. New devices that connect are added here automatically."
                                           Foreground="{StaticResource Muted}" FontSize="12" TextWrapping="Wrap" Margin="0,2,0,0" />
                            </StackPanel>
                            <Button Grid.Column="1" Style="{StaticResource GhostButton}" Content="+ Add device"
                                    VerticalAlignment="Top" Click="AddDevice_Click" />
                        </Grid>

                        <!-- drag-to-arrange canvas (Windows Display-settings style) -->
                        <Border Margin="0,12,0,0" Background="#0B0E1A" BorderBrush="{StaticResource Line}"
                                BorderThickness="1" CornerRadius="10" Height="300" ClipToBounds="True">
                            <Canvas x:Name="LayoutCanvas" Background="Transparent" />
                        </Border>

                        <!-- selected-device editor -->
                        <Grid x:Name="SelectionBar" Margin="0,12,0,0" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Name" Foreground="{StaticResource Muted}"
                                       VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBox x:Name="SelNameBox" Grid.Column="1" />
                            <Button x:Name="SelRemove" Grid.Column="2" Style="{StaticResource GhostButton}"
                                    Content="Remove" Margin="8,0,0,0" Click="RemoveSelected_Click" />
                        </Grid>

                        <Grid Margin="0,12,0,0" HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Port" Foreground="{StaticResource Muted}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBox x:Name="PortBox" Text="24800" Width="90" />
                            </StackPanel>
                        </Grid>

                        <CheckBox x:Name="TlsCheck" Content="Use encryption (TLS) — leave OFF for tablets" Foreground="{StaticResource Ink}"
                                  Margin="2,14,0,0" IsChecked="False" />

                        <TextBlock x:Name="IpText" Text="" Foreground="{StaticResource Muted}" Margin="2,12,0,0" />
                    </StackPanel>
                </Border>

                <!-- Multi-controller (beta) -->
                <Border Style="{StaticResource Card}" Margin="0,14,0,0">
                    <StackPanel>
                        <TextBlock Text="Multi-controller (beta)" FontWeight="SemiBold" FontSize="15" />
                        <TextBlock Text="Share control with another Windows/Mac computer: type on whichever machine you're sitting at and it takes over. (Desktop↔desktop; ~1s switch. Untested across machines — feedback welcome.)"
                                   Foreground="{StaticResource Muted}" FontSize="12" TextWrapping="Wrap" Margin="0,2,0,8" />
                        <CheckBox x:Name="MultiEnable" Content="Enable handing control between computers"
                                  Foreground="{StaticResource Ink}" />
                        <TextBlock Text="Other computer's IP address" Foreground="{StaticResource Muted}" Margin="2,12,0,4" />
                        <TextBox x:Name="PeerIpBox" Width="220" HorizontalAlignment="Left" />
                        <TextBlock x:Name="RoleText" Text="Role: idle" Foreground="{StaticResource Muted}" Margin="2,10,0,0" />
                    </StackPanel>
                </Border>

                <!-- Activity log -->
                <Border Style="{StaticResource Card}" Margin="0,14,0,0">
                    <StackPanel>
                        <TextBlock Text="Activity" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,10" />
                        <TextBox x:Name="LogBox" Height="150" IsReadOnly="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto" FontFamily="Cascadia Mono, Consolas"
                                 FontSize="12" Background="#0B0E1A" />
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
